APP_NAME=vaultOne API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vaultone_db

JWT_SECRET_KEY=change-this-to-a-long-random-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=VaultOne
SMTP_USE_TLS=true

BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=VaultOne
# BREVO_SENDER_EMAIL and BREVO_SENDER_NAME are also accepted for compatibility.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=30

CLOUDINARY_URL=
# Or configure the Cloudinary values separately:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# cloudinary = authenticated private transfer assets; local = development only
VAULT_CONNECT_STORAGE_BACKEND=cloudinary

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
